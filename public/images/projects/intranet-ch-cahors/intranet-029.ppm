ґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґ,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,ааа                                                                                                                                                                                                                                                                                                                                                                           іііьььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььёёёьььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььЁЁЁґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґ,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,ааа                                                                                                                                                                                                                                                                                                                                                                           іііьььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььёёёьььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььььЁЁЁґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґґ